{
  "openapi": "3.1.0",
  "info": {
    "title": "test-skill skill",
    "description": "A minimal test skill for compiler validation.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://skills.openskill.ai"
    }
  ],
  "paths": {
    "/test-skill/invoke": {
      "post": {
        "operationId": "invoke_test_skill",
        "summary": "Load a phase of the test-skill skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "phase-zero"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}