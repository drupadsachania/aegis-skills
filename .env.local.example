# Copy this to .env.local and fill in your values
# NEVER commit .env.local — it is gitignored

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Themis — AI orchestration layer
# Set at least one provider key. Keys are server-side only and never sent to the client.
THEMIS_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Supabase (already required by Aegis)
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY must already be set
