{
  "openapi": "3.1.0",
  "info": {
    "title": "governance skill",
    "description": "Security governance programme design and management. Covers policy framework development, programme maturity assessment (NIST CSF 2.0 tiers, CMMC), security metrics and board reporting, and third-party governance (TPRM). Triggers for: security policy development, maturity assessment, board reporting, KPI/KRI design, vendor risk programme, or security steering committee setup.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aegis-skills.vercel.app"
    }
  ],
  "paths": {
    "/governance/invoke": {
      "post": {
        "operationId": "invoke_governance",
        "summary": "Load a phase of the governance skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "policy-framework",
                      "program-maturity",
                      "metrics-and-reporting",
                      "third-party-governance"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}