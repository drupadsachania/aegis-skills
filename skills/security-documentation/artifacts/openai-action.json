{
  "openapi": "3.1.0",
  "info": {
    "title": "security-documentation skill",
    "description": "Security documentation authoring workflow for policies, runbooks, and incident response templates. Triggers for: new security policy creation, IR runbook authoring, compliance documentation, or any exercise requiring structured security writing that meets audit and operational standards.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aegis-skills.vercel.app"
    }
  ],
  "paths": {
    "/security-documentation/invoke": {
      "post": {
        "operationId": "invoke_security_documentation",
        "summary": "Load a phase of the security-documentation skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "policy-writing",
                      "runbook-authoring",
                      "incident-templates"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}