{
  "openapi": "3.1.0",
  "info": {
    "title": "compliance skill",
    "description": "End-to-end security compliance workflow covering scope definition, regulatory mapping, control assessment, evidence collection, and remediation roadmap. Supports SOC 2, ISO 27001:2022, PCI-DSS v4.0, HIPAA, GDPR, NIST CSF 2.0, and CIS Controls v8. Triggers for: compliance audit preparation, control gap assessment, evidence collection, regulatory mapping, or remediation planning.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aegis-skills.vercel.app"
    }
  ],
  "paths": {
    "/compliance/invoke": {
      "post": {
        "operationId": "invoke_compliance",
        "summary": "Load a phase of the compliance skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "scope-definition",
                      "standard-mapping",
                      "control-assessment",
                      "evidence-collection",
                      "remediation-roadmap"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}