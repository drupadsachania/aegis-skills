      "mimeType": "text/markdown"
    },
    {
      "uri": "https://aegis-skills.vercel.app/compliance/phase/remediation-roadmap",
      "name": "remediation-roadmap",
      "description": "Reference content for compliance — remediation-roadmap",
      "mimeType": "text/markdown"
    }
  ]
