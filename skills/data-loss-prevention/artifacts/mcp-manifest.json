        "type": "object",
        "required": [
          "phase"
        ],
        "properties": {
          "phase": {
            "type": "string",
            "description": "Phase ID to load",
            "enum": [
              "data-classification",
              "network-dlp",
              "endpoint-dlp",
              "email-and-saas-dlp",
              "cloud-and-storage-dlp",
              "exfiltration-detection-and-response"
            ]
          }
        }
      }
    }
  ],
