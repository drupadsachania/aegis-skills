{
  "openapi": "3.1.0",
  "info": {
    "title": "identity-access-management skill",
    "description": "Comprehensive IAM programme covering identity governance (Joiners/Movers/Leavers), human authentication (FIDO2, SSO, passwordless), privileged access management (PAM), non-human identities (service accounts, API keys, secrets), AI/agent identity, and access review and audit. Triggers for: MFA deployment, PAM design, secrets management, identity governance, agent identity, or access review programme.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aegis-skills.vercel.app"
    }
  ],
  "paths": {
    "/identity-access-management/invoke": {
      "post": {
        "operationId": "invoke_identity_access_management",
        "summary": "Load a phase of the identity-access-management skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "identity-governance",
                      "human-authentication",
                      "privileged-access-management",
                      "non-human-identities",
                      "agent-and-ai-identities",
                      "access-review-and-audit"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}