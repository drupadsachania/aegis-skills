{
  "openapi": "3.1.0",
  "info": {
    "title": "threat-modeling skill",
    "description": "Structured threat modelling workflow using STRIDE and PASTA methodologies. Triggers for: new system design review, pre-release threat model, architectural security review, or any exercise requiring a systematic attacker-perspective analysis of a system's design.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://project-iud7o.vercel.app"
    }
  ],
  "paths": {
    "/threat-modeling/invoke": {
      "post": {
        "operationId": "invoke_threat_modeling",
        "summary": "Load a phase of the threat-modeling skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "scope-definition",
                      "data-flow-diagramming",
                      "threat-enumeration",
                      "mitigation-mapping"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}