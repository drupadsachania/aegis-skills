{
  "openapi": "3.1.0",
  "info": {
    "title": "infrastructure-security skill",
    "description": "Infrastructure security assessment workflow covering asset discovery, configuration baseline, patch management, hardening controls, and compliance validation. Use for CIS Benchmark assessments, cloud security posture reviews, or infrastructure hardening sprints.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aegis-skills.vercel.app"
    }
  ],
  "paths": {
    "/infrastructure-security/invoke": {
      "post": {
        "operationId": "invoke_infrastructure_security",
        "summary": "Load a phase of the infrastructure-security skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "asset-discovery",
                      "configuration-baseline",
                      "patch-management",
                      "hardening-controls",
                      "compliance-validation"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}