{
  "openapi": "3.1.0",
  "info": {
    "title": "security-operations skill",
    "description": "Full security operations workflow covering the complete SOC operating model — from alert triage through threat intelligence, vulnerability management, incident detection, incident response, post-incident review, metrics, and compliance reporting. Designed for SOC analysts, security engineers, and security managers running operational security programmes.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://project-iud7o.vercel.app"
    }
  ],
  "paths": {
    "/security-operations/invoke": {
      "post": {
        "operationId": "invoke_security_operations",
        "summary": "Load a phase of the security-operations skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "alert-triage",
                      "threat-intelligence",
                      "vulnerability-management",
                      "incident-detection",
                      "incident-response",
                      "post-incident-review",
                      "security-metrics",
                      "compliance-reporting"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}