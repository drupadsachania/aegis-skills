{
  "openapi": "3.1.0",
  "info": {
    "title": "threat-hunting skill",
    "description": "Proactive threat hunting workflow. Triggers for: structured hunt campaigns, TTP-based hypothesis generation, SIEM query development, anomaly investigation, or any exercise requiring proactive adversary search in telemetry rather than reactive alert response.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://project-iud7o.vercel.app"
    }
  ],
  "paths": {
    "/threat-hunting/invoke": {
      "post": {
        "operationId": "invoke_threat_hunting",
        "summary": "Load a phase of the threat-hunting skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "hypothesis-generation",
                      "data-collection",
                      "detection-logic",
                      "investigation",
                      "reporting"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}