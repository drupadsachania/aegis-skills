  "schema": "mcp/1.0",
  "name": "application-security",
  "version": "1.0.0",
  "description": "Application security assessment workflow covering threat modelling, static analysis, dependency auditing, API security, and security testing. Triggers for: pre-release security review, SAST/DAST gap analysis, API security hardening, or OWASP Top 10 remediation planning.\n",
