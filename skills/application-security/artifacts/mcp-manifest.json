          "phase"
        ],
        "properties": {
          "phase": {
            "type": "string",
            "description": "Phase ID to load",
            "enum": [
              "threat-modeling-appsec",
              "sast-review",
              "dependency-audit",
              "api-security",
              "security-testing"
            ]
          }
        }
      }
    }
  ],
