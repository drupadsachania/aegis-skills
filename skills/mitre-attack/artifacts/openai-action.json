{
  "openapi": "3.1.0",
  "info": {
    "title": "mitre-attack skill",
    "description": "MITRE ATT&CK threat modelling workflow. Triggers for: adversary TTP mapping, threat actor profiling, kill chain analysis, technique selection for security controls, ATT&CK Navigator usage, ICS/OT threat modelling, ATT&CK-based detection gap analysis, or any exercise requiring adversary behaviour mapping.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://skills.openskill.ai"
    }
  ],
  "paths": {
    "/mitre-attack/invoke": {
      "post": {
        "operationId": "invoke_mitre_attack",
        "summary": "Load a phase of the mitre-attack skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "enterprise-matrix-overview",
                      "ics-matrix-overview",
                      "ttp-profiling-guide"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}