  "context": {
    "environments": [
      "enterprise",
      "cloud",
      "hybrid",
      "saas"
    ],
    "industry-verticals": [
      "financial-services",
      "healthcare",
      "government",
      "retail",
      "technology"
    ],
    "attack-surface-tags": [
      "external-exposure",
      "reconnaissance",
      "cloud-misconfiguration",
      "internet-facing",
      "shadow-it"
    ]
  }
