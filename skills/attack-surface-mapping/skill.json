{
  "osk": "1.0",
  "name": "attack-surface-mapping",
  "version": "1.0.0",
  "description": "Attack surface mapping and exposure analysis workflow. Triggers for: external attack surface assessment, internet-facing asset discovery, cloud misconfiguration audit, or any exercise requiring a comprehensive map of an organisation's exploitable exposure.\n",
  "frameworks": [
    "mitre-attack",
    "owasp-asvs"
  ],
  "tags": [
    "security",
    "attack-surface",
    "reconnaissance",
    "exposure",
    "cloud-security",
    "external-assets"
  ],
  "phases": [
    {
      "id": "external-discovery",
      "lazy": false,
      "tokens": 676
    },
    {
      "id": "internal-enumeration",
      "lazy": true,
      "tokens": 594
    },
    {
      "id": "cloud-exposure",
      "lazy": true,
      "tokens": 762
    },
    {
      "id": "risk-prioritization",
      "lazy": true,
      "tokens": 706
    },
    {
      "id": "cve-exposure-management",
      "lazy": true,
      "tokens": 1242
    }
  ],
  "endpoints": {
    "mcp": "mcp://aegis-skills.vercel.app/attack-surface-mapping",
    "action": "https://aegis-skills.vercel.app/attack-surface-mapping/invoke",
    "artifacts": "https://aegis-skills.vercel.app/attack-surface-mapping/download"
  },
  "research": {
    "feeds": [
      "shodan-feed",
      "censys-feed",
      "cisa-advisories"
    ],
    "red-team": true
  },
  "self-learning": {
    "update-frequency": "weekly",
    "sources": [
      "nvd-cve-feed",
      "shodan-monitored",
      "cisa-advisories"
    ],
    "health-score": 1,
    "stale-threshold-days": 30,
    "coverage-gaps": []
