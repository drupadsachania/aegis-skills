{
  "openapi": "3.1.0",
  "info": {
    "title": "network-security skill",
    "description": "Network security assessment and hardening workflow. Triggers for: network segmentation review, traffic analysis, firewall rule audits, network inventory, perimeter hardening, lateral movement prevention, or any exercise requiring network threat surface reduction.\n",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aegis-skills.vercel.app"
    }
  ],
  "paths": {
    "/network-security/invoke": {
      "post": {
        "operationId": "invoke_network_security",
        "summary": "Load a phase of the network-security skill",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phase"
                ],
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Which phase to load",
                    "enum": [
                      "network-inventory",
                      "segmentation-review",
                      "traffic-analysis",
                      "hardening-checklist"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phase content returned as markdown",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phase": {
                      "type": "string"
                    },
                    "content": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}